{
  "name": "template-pipeline",
  "version": "1.0",
  "description": "Apply template to multiple media sets and render all outputs",
  "variables": {
    "templatePath": "./templates/social-vertical.json",
    "outputDir": "./output"
  },
  "steps": [
    {
      "id": "apply-1",
      "type": "command",
      "command": "of",
      "args": {
        "arg0": "apply-template",
        "arg1": "-t",
        "arg2": "${templatePath}",
        "arg3": "-m",
        "arg4": "./media/set1/intro.mp4",
        "arg5": "./media/set1/main.mp4",
        "arg6": "-o",
        "arg7": "${outputDir}/project-1.json",
        "arg8": "--render",
        "arg9": "--render-output",
        "arg10": "${outputDir}/video-1.mp4"
      }
    },
    {
      "id": "apply-2",
      "type": "command",
      "command": "of",
      "args": {
        "arg0": "apply-template",
        "arg1": "-t",
        "arg2": "${templatePath}",
        "arg3": "-m",
        "arg4": "./media/set2/intro.mp4",
        "arg5": "./media/set2/main.mp4",
        "arg6": "-o",
        "arg7": "${outputDir}/project-2.json",
        "arg8": "--render",
        "arg9": "--render-output",
        "arg10": "${outputDir}/video-2.mp4"
      }
    },
    {
      "id": "analyze-all",
      "type": "command",
      "command": "of",
      "args": {
        "arg0": "analyze",
        "arg1": "-i",
        "arg2": "${outputDir}/video-1.mp4",
        "arg3": "-t",
        "arg4": "full"
      },
      "dependsOn": ["apply-1"]
    }
  ]
}
