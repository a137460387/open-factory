{
  "name": "open-factory",
  "license": "MIT",
"version": "4.25.3",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Local-first desktop video editor with AI-powered editing and plugin extensibility.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a137460387/open-factory.git"
  },
  "homepage": "https://github.com/a137460387/open-factory#readme",
  "bugs": {
    "url": "https://github.com/a137460387/open-factory/issues"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/desktop && bun run dev",
    "create-plugin": "bun tools/create-plugin/index.ts",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "e2e": "cd apps/desktop && bun run e2e",
    "e2e:headed": "cd apps/desktop && bun run e2e:headed",
    "e2e:ui": "cd apps/desktop && bun run e2e:ui",
    "build": "tsc -p packages/editor-core/tsconfig.build.json && tsc -p packages/plugin-sdk/tsconfig.build.json && cd apps/desktop && bun run build",
    "tauri:dev": "cd apps/desktop && bun run tauri:dev",
    "tauri:build": "cd apps/desktop && bun run tauri:build",
    "smoke:tauri": "cd apps/desktop && bun run smoke:tauri",
    "smoke:preview": "cd apps/desktop && bun run smoke:preview",
    "smoke:dialog": "cd apps/desktop && bun run smoke:dialog",
    "smoke:cancel": "cd apps/desktop && bun run smoke:cancel",
    "smoke:golden": "cd apps/desktop && bun run smoke:golden",
    "media:compat": "node scripts/media-compat-test.mjs",
    "check:release": "node scripts/check-release.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.1.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  },
  "dependencies": {
  }
}
