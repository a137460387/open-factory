{
  "name": "open-factory",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Local-first desktop video editor MVP.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/desktop && bun run dev",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "e2e": "cd apps/desktop && bun run e2e",
    "e2e:headed": "cd apps/desktop && bun run e2e:headed",
    "e2e:ui": "cd apps/desktop && bun run e2e:ui",
    "build": "tsc -p packages/editor-core/tsconfig.build.json && cd apps/desktop && bun run build",
    "tauri:dev": "cd apps/desktop && bun run tauri:dev",
    "tauri:build": "cd apps/desktop && bun run tauri:build",
    "smoke:tauri": "cd apps/desktop && bun run smoke:tauri",
    "smoke:preview": "cd apps/desktop && bun run smoke:preview",
    "smoke:dialog": "cd apps/desktop && bun run smoke:dialog",
    "smoke:cancel": "cd apps/desktop && bun run smoke:cancel",
    "smoke:golden": "cd apps/desktop && bun run smoke:golden"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
