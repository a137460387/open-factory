{
  "name": "@open-factory/auth",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Authentication and SSO module for Open Factory (OIDC, SAML 2.0)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "passport": "^0.7.0",
    "openid-client": "^6.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/passport": "^1.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.7"
  }
}
