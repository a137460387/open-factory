# API Gateway Environment Variables

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ISSUER=open-factory
JWT_AUDIENCE=open-factory-api
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://localhost:5432/open_factory
DB_POOL_SIZE=10
DB_SSL=false

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_PRETTY=false
