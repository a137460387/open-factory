{
  "name": "@open-factory/ai-generator",
  "version": "0.1.0",
  "description": "Local generative AI module for Open Factory",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "onnxruntime-web": "^1.19.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7"
  },
  "peerDependencies": {
    "ffmpeg.wasm": "^0.12.0"
  },
  "peerDependenciesMeta": {
    "ffmpeg.wasm": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
