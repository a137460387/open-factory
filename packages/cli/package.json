{
  "name": "@open-factory/cli",
  "version": "0.1.0",
  "description": "Command-line interface for Open Factory video editor engine",
  "license": "MIT",
  "type": "module",
  "bin": {
    "of": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run ../../packages/cli/__tests__ --coverage"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "@open-factory/editor-core": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
