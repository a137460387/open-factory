{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/editor-core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/desktop": {
      "entry": ["src/main.tsx", "src/App.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": [
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/e2e/**"
  ],
  "include": ["exports", "types"]
}
